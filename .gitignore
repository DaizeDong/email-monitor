__pycache__/
*.pyc
*.log
logs/
.DS_Store
Thumbs.db
desktop.ini
*.state.json
.pytest_cache/

# self-evolve run artifacts (events/worktrees/state)
.sie/

# --- secrets / private config (defensive: never let local test config or
#     credentials slip into this public repo; HIGH audit fix, round 2) ---
.env
*.env
!*.env.template
.credentials.json
config.json
secrets.json
# Secrets gate (config-spec E6 / Mode B) — never commit a local/test companion config's secrets,
# but keep the committed scaffolding (README / .gitkeep / env template).
secrets/*
!secrets/README.md
!secrets/.gitkeep
!secrets/_accounts.env.template
*.secret
*.secrets
*.cred
*.creds
registry.json
rules/merged.json
rules/_personal_layer.json
resolve-cred.ps1
.pw-auth/
*.token
*.pem
*.key
