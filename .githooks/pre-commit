#!/bin/sh
# PER-REPO pre-commit -- the STRICT gate, for a repo we own and have cleaned.
# (Enable with: git config core.hooksPath .githooks -- local config, so every clone must run the
#  installer once. CI does not depend on it.)
#
# Two checks, and they answer DIFFERENT questions:
#
#   pii_guard      "does this content look private?"   -- a sieve at the exit. Catches what it has
#                                                          been taught to recognize.
#   data_boundary  "could this have been generated?"   -- catches what no sieve can: a real record
#                                                          that looks perfectly innocuous. The golden
#                                                          fixture must be byte-identical to what
#                                                          tools/make_fixtures.py emits, and a real
#                                                          email CANNOT be regenerated. That is the
#                                                          whole mechanism.
#
# The 2026-07 leak in this repo was a test fixture built by pasting real emails out of the operator's
# inbox. Scrubbing it fixed that file and nothing else -- the next agent needing a realistic test case
# is still holding a real inbox, and copy-paste is still the cheapest move available. data_boundary is
# what makes that move FAIL, here, at commit time, instead of in an audit months later.
#
# Scope: the whole git-tracked tree, under the full synthetic-namespace rule -- nothing that merely
# LOOKS like a real-world identifier gets in, including a vendor nobody anticipated. That is stricter
# than the machine-wide hook (the global hook dir), which only checks the staged
# diff for breach classes because it also has to run in forks and research code without nagging.
#
# WHY THE OUTPUT IS CAPTURED INSTEAD OF PRINTED DIRECTLY (this bit is load-bearing):
# The obvious form is `"$PY" "$GUARD" --tree || exit 1`. It has a real hole, observed 2026-07-13:
# run `git commit | head -8`, let the guard print more than 8 lines, and `head` closes the pipe
# mid-write. The guard dies on the broken pipe, its exit status stops meaning what we think it means,
# and the commit sails through -- while the findings are still on screen, so it LOOKS like it blocked.
# A gate whose verdict the caller's pager can destroy is not a gate. So: capture the output, record
# the exit code with nothing in between, and decide from the code alone. Both checks below do this.
ROOT="$(git rev-parse --show-toplevel)"
GUARD="$ROOT/tools/pii_guard.py"
BOUNDARY="$ROOT/tools/data_boundary.py"
PY=$(command -v python || command -v python3 || command -v py) || exit 0

# --- 1. content: does anything here look private? -----------------------------------------------
if [ -f "$GUARD" ]; then           # not vendored into this repo yet: do not block
    out=$("$PY" "$GUARD" --tree 2>&1)
    rc=$?
    if [ "$rc" -ne 0 ]; then
        printf '%s\n' "$out"
        echo ""
        echo "pre-commit BLOCKED by pii_guard. Do not reach for --no-verify:"
        echo "right now the fix is an edit; after this commit it is a history rewrite."
        exit 1
    fi
fi

# --- 2. provenance: could every fixture have been generated? ------------------------------------
if [ -f "$BOUNDARY" ]; then        # not vendored into this repo yet: do not block
    out=$("$PY" "$BOUNDARY" 2>&1)
    rc=$?
    if [ "$rc" -ne 0 ]; then
        printf '%s\n' "$out"
        echo ""
        echo "pre-commit BLOCKED by data_boundary. A fixture no longer matches its generator."
        echo "If you hand-edited the golden file: do not. Edit the CASE TABLE in"
        echo "tools/make_fixtures.py, then run: python tools/make_fixtures.py"
        echo "If you pasted in a real message: that is exactly what this gate is for."
        exit 1
    fi
fi

exit 0
